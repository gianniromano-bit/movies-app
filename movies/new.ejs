<h1>Add Movie</h1>
<% if (error) { %>
    <p>
        <%= error %>
    </p>
    <% } %>

        <form method="POST">
            <input name="name" placeholder="Name">
            <input name="year" placeholder="Year">
            <input name="genres" placeholder="Action,Drama">
            <input name="rating" placeholder="Rating">
            <textarea name="description"></textarea>
            <button>Add</button>
        </form>
