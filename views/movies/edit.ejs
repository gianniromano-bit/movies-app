<%- include('../partials/header.ejs', {title: 'Edit Movie'}) %>

<h2>Edit Movie</h2>

<% if (error) { %>
    <p style="color:red;"><%= error %></p>
<% } %>

<form method="POST" action="/movies/<%= movie._id %>?_method=PUT" class="form-container">
    <label for="name">Name</label>
    <input type="text" name="name" id="name" value="<%= movie.name %>">

    <label for="year">Year</label>
    <input type="number" name="year" id="year" value="<%= movie.year %>">

    <label for="genres">Genres (comma separated)</label>
    <input type="text" name="genres" id="genres" value="<%= movie.genres.join(',') %>">

    <label for="rating">Rating</label>
    <input type="number" name="rating" id="rating" step="0.1" value="<%= movie.rating %>">

    <label for="description">Description</label>
    <textarea name="description" id="description"><%= movie.description %></textarea>

    <button type="submit" class="submit-btn">Update Movie</button>
</form>

<a href="/movies/<%= movie._id %>">Cancel</a>

<%- include('../partials/footer.ejs') %>
